# Server
PORT=3001
NODE_ENV=test

# Database (must point to a SEPARATE database from dev — it gets truncated between tests)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/spec_to_system_test?schema=public"

# JWT (use different secrets than dev/prod)
JWT_ACCESS_SECRET=replace-me-with-strong-random-string-32chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-me-with-another-strong-random-string-32chars
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# CORS
CORS_ORIGIN=http://localhost:5173
